# Set default behavior to handle line endings automatically.
* text=auto

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flac binary
*.ogg binary
*.pfx binary
*.pyc binary

# Normalize line endings to LF for code files to ensure cross-platform consistency.
*.java text eol=lf
*.json text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Explicitly set CRLF for batch files since they are Windows-specific.
*.bat text eol=crlf
